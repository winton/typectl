{
  "name": "typectl",
  "version": "3.1.0",
  "description": "TypeScript control flow library",
  "main": "./dist/cjs/typectl.js",
  "module": "./dist/esm/typectl.js",
  "types": "./dist/cjs/typectl.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/typectl.d.ts",
        "default": "./dist/esm/typectl.js"
      },
      "require": {
        "types": "./dist/cjs/typectl.d.ts",
        "default": "./dist/cjs/typectl.js"
      }
    }
  },
  "scripts": {
    "build": "./bin/build",
    "prepare": "husky install",
    "prepublishOnly": "npm run build",
    "start": "./bin/watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "update": "npx npm-check-updates -u"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/winton/typectl.git"
  },
  "author": "Winton Welsh <mail@wintoni.us>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/winton/typectl/issues"
  },
  "homepage": "https://github.com/winton/typectl#readme",
  "dependencies": {
    "web-streams-polyfill": "4.2.0"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{css,json,md}": "prettier --write",
    "*.{js,ts}": "eslint --fix"
  }
}
